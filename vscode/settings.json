{
    // Editor
    "editor.bracketPairColorization.enabled": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "editor.linkedEditing": true,
    "editor.renderControlCharacters": true,
    "editor.renderWhitespace": "all",
    "editor.snippetSuggestions": "top",
    "editor.suggestSelection": "first",
    "editor.tabSize": 2,
    "diffEditor.ignoreTrimWhitespace": false,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },

    // ESLint
    "eslint.format.enable": true,
    "eslint.codeActionsOnSave.mode": "problems",

    // Files & Search
    "files.trimTrailingWhitespace": true,
    "search.exclude": {
        "**/node_modules": false
    },
    "workbench.editor.empty.hint": "hidden",

    // Terminal
    "terminal.external.osxExec": "cmux.app",
    "terminal.explorerKind": "external",
    "terminal.integrated.allowMnemonics": true,
    "terminal.integrated.enableVisualBell": true,
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.scrollback": 300000,
    "accessibility.signals.terminalBell": {
        "sound": "on"
    },

    // Git & SCM
    "git.mergeEditor": true,
    "git.openRepositoryInParentFolders": "never",
    "git.timeline.date": "committed",
    "scm.defaultViewMode": "tree",
    "scm.graph.badges": "all",

    // GitLens
    "gitlens.telemetry.enabled": false,
    "gitlens.views.commitDetails.files.layout": "tree",
    "gitlens.views.worktrees.branches.layout": "list",

    // Project Manager
    "projectManager.git.baseFolders": [
        "~/repos"
    ],

    // Snyk
    "snyk.yesWelcomeNotification": false,
    "snyk.severity": {
        "low": false
    },
    "snyk.features.infrastructureAsCode": false,
    "snyk.scanningMode": "manual",
    "snyk.trustedFolders": [
        "/Users/martinburch/repos/neb-database-migrator",
        "/Users/martinburch/repos/neb-demo-data",
        "/Users/martinburch/repos/neb-deploy",
        "/Users/martinburch/repos/neb-local-dev",
        "/Users/martinburch/repos/neb-microservice",
        "/Users/martinburch/repos/neb-ms-appointments",
        "/Users/martinburch/repos/neb-ms-billing",
        "/Users/martinburch/repos/neb-ms-charting",
        "/Users/martinburch/repos/neb-ms-clearinghouse",
        "/Users/martinburch/repos/neb-ms-conversion",
        "/Users/martinburch/repos/neb-ms-core",
        "/Users/martinburch/repos/neb-ms-electronic-claims",
        "/Users/martinburch/repos/neb-ms-email",
        "/Users/martinburch/repos/neb-ms-files",
        "/Users/martinburch/repos/neb-ms-image",
        "/Users/martinburch/repos/neb-ms-macro-metadata",
        "/Users/martinburch/repos/neb-ms-mock-chc",
        "/Users/martinburch/repos/neb-ms-mock-cognito",
        "/Users/martinburch/repos/neb-ms-mock-doctible",
        "/Users/martinburch/repos/neb-ms-partner",
        "/Users/martinburch/repos/neb-ms-payments",
        "/Users/martinburch/repos/neb-ms-pdf",
        "/Users/martinburch/repos/neb-ms-permissions",
        "/Users/martinburch/repos/neb-ms-registry",
        "/Users/martinburch/repos/neb-ms-reports",
        "/Users/martinburch/repos/neb-ms-x12",
        "/Users/martinburch/repos/neb-pipe-data-funnel",
        "/Users/martinburch/repos/neb-pipe-warehouse-sink",
        "/Users/martinburch/repos/neb-www",
        "/Users/martinburch/repos/neb-api",
        "/Users/martinburch/repos/neb-rollup-plugins",
        "/Users/martinburch/repos/neb-forked-mysql-import",
        "/Users/martinburch/repos/neb-utilities",
        "/Users/martinburch/repos/neb-pipe-compare",
        "/Users/martinburch/repos/neb-integration-test",
        "/Users/martinburch/repos/neb-test-support",
        "/Users/martinburch/repos/neb-sequelize-model-validator",
        "/Users/martinburch/repos/neb-elastic",
        "/Users/martinburch/repos/neb-integration-helper",
        "/Users/martinburch/repos/neb-proxy"
    ],
    "snyk.advanced.cliPath": "/Users/martinburch/Library/Application Support/snyk-ls/snyk-macos-arm64",

    // Datadog
    "datadog.ust.environment.setup.focusedName": "prod",
    "datadog.telemetry.setup.enableTelemetry": "disabled",
    "datadog.telemetry.setup.enableAgentObservability": false,
    "datadog.timeRange.setup.timeFrame": "4h",

    // Telemetry
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "redhat.telemetry.enabled": false,
    "typescript.surveys.enabled": false,

    // AI
    "github.copilot.enable": false,
    "chat.commandCenter.enabled": false,
    "terminal.integrated.initialHint": false,

    // UI
    "workbench.activityBar.orientation": "horizontal",

    // Mirrord
    "mirrord.promptUsingBinary": false,

    // Rust
    "rust-analyzer.check.command": "clippy",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "Cargo.toml": "Cargo.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    }
}
